---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Card, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import MeasurementSketch from "@/components/measurementSketch";
---

<AdminLayout title="Detail Pesanan">
  <div class="container mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-slate-500 hover:text-slate-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
      </a>
      <h1 class="text-2xl font-bold tracking-tight text-slate-950">Detail Pesanan</h1>
    </div>

    <Card class="overflow-hidden border-2 shadow-xl">
      <CardHeader>
        <CardTitle id="order-title">Memuat...</CardTitle>
      </CardHeader>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-slate-100">

        {/* KIRI: Fields display-only */}
        <div class="px-8 pb-8 pt-6 space-y-6 bg-white">
          <div class="grid grid-cols-1 gap-6">
            <div class="grid grid-cols-3 gap-3">
              <div class="col-span-2 space-y-2">
                <Label>Nama Pelanggan</Label>
                <Input id="field-name" className="h-12 text-base border-2 bg-slate-50" disabled />
              </div>
              <div class="space-y-2">
                <Label>No. HP / WA</Label>
                <Input id="field-phone" className="h-12 text-base border-2 bg-slate-50" disabled />
              </div>
            </div>

            <div class="space-y-2">
              <Label>Jenis Pakaian</Label>
              <Input id="field-outfit" className="h-12 text-base border-2 bg-slate-50" disabled />
            </div>

            <div class="grid grid-cols-3 gap-4 items-end">
              <div class="space-y-2">
                <Label>P Kain (m)</Label>
                <Input id="field-panjang-kain" className="h-12 border-2 bg-slate-50" disabled />
              </div>
              <div class="space-y-2">
                <Label>L Kain (m)</Label>
                <Input id="field-lebar-kain" className="h-12 border-2 bg-slate-50" disabled />
              </div>
              <div class="flex flex-col items-center gap-1 pb-2">
                <Label class="text-xs text-center">Cuci Dulu?</Label>
                <span id="field-cuci" class="text-sm font-medium px-3 py-1.5 rounded-md bg-slate-100 text-slate-600">—</span>
              </div>
            </div>
          </div>

          <hr />

          <div id="measurement-fields" class="grid px-3 grid-cols-2 gap-x-9 gap-y-6"></div>

          <div id="catatan-section" class="space-y-2 hidden">
            <Label>Catatan</Label>
            <textarea
              id="field-catatan"
              disabled
              class="w-full min-h-[80px] rounded-md border-2 border-input bg-slate-50 px-3 py-2 text-base resize-none"
            ></textarea>
          </div>

          <hr />

          {/* Status update section */}
          <div class="space-y-4">
            <Label class="text-base font-semibold">Ubah Status</Label>
            <div class="flex gap-3 items-end">
              <div class="flex-1 space-y-2">
                <Label class="text-sm text-slate-500">Status berikutnya</Label>
                <select
                  id="status-select"
                  class="w-full h-12 rounded-md border-2 border-input bg-background px-3 py-2 text-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                >
                </select>
              </div>
              <Button
                id="save-status-btn"
                type="button"
                className="h-12 px-6 bg-indigo-600 hover:bg-indigo-700 font-semibold"
              >
                Simpan Status
              </Button>
            </div>
          </div>
        </div>

        {/* KANAN: Sketch */}
        <div class="p-6 bg-slate-50 flex flex-col justify-center items-center min-h-[600px]">
          <p class="text-sm text-slate-500 mb-3 font-medium">Pratinjau Sketsa</p>
          <div class="w-full h-full" style="min-height: 500px;">
            <MeasurementSketch client:only="react" />
          </div>
        </div>
      </div>
    </Card>
  </div>

  <script>
    import { db, STATUS_FLOW } from "@/lib/db";
    import { trx } from "@/lib/supabase";
    import type { OrderStatus } from "@/lib/db";
    import { toast } from "sonner";

    const orderId = Number(new URLSearchParams(window.location.search).get('id'));

    const JAS_FIELDS: [string, string, string][] = [
      ["panjangBadan",       "Panjang Badan",       "panjang_badan"],
      ["lebarBahu",          "Lebar Bahu",           "lebar_bahu"],
      ["panjangLengan",      "Panjang Lengan",       "panjang_lengan"],
      ["lingkarLengan",      "Lingkar Lengan",       "lingkar_lengan"],
      ["lingkarUjungLengan", "Lingkar Ujung Lengan", "lingkar_ujung_lengan"],
      ["lingkarDada",        "Lingkar Dada",         "lingkar_dada"],
      ["lingkarPerut",       "Lingkar Perut",        "lingkar_perut"],
      ["lingkarPinggul",     "Lingkar Pinggul",      "lingkar_pinggul"],
    ];

    const KEMEJA_PANJANG_FIELDS: [string, string, string][] = [
      ["lingkarLeher",       "Lingkar Leher",        "lingkar_leher"],
      ["lebarBahu",          "Lebar Bahu",           "lebar_bahu"],
      ["panjangLengan",      "Panjang Lengan",       "panjang_lengan"],
      ["lingkarDada",        "Lingkar Dada",         "lingkar_dada"],
      ["lingkarPerut",       "Lingkar Perut",        "lingkar_perut"],
      ["panjangBadan",       "Panjang Badan",        "panjang_badan"],
      ["lingkarUjungLengan", "Lingkar Ujung Lengan", "lingkar_ujung_lengan"],
      ["lingkarPinggul",     "Lingkar Pinggul",      "lingkar_pinggul"],
    ];

    const KEMEJA_PENDEK_FIELDS: [string, string, string][] = [
      ["lingkarLeher",   "Lingkar Leher",  "lingkar_leher"],
      ["lebarBahu",      "Panjang Bahu",   "lebar_bahu"],
      ["panjangLengan",  "Panjang Lengan", "panjang_lengan"],
      ["lebarPundak",    "Lebar Pundak",   "lebar_pundak"],
      ["lingkarDada",    "Lebar Dada",     "lingkar_dada"],
      ["panjangBadan",   "Panjang Badan",  "panjang_badan"],
      ["lingkarLengan",  "Lingkar Lengan", "lingkar_lengan"],
      ["lingkarPinggul", "Lebar Pinggul",  "lingkar_pinggul"],
    ];

    function isKemejaLenganPendek(outfit: string) {
      return outfit.toLowerCase().includes('kemeja') && outfit.toLowerCase().includes('pendek');
    }

    function isKemejaLenganPanjang(outfit: string) {
      return outfit.toLowerCase().includes('kemeja') && outfit.toLowerCase().includes('panjang');
    }

    function renderFields(order: Record<string, any>) {
      const outfit = order.outfit_type ?? '';
      let fields = JAS_FIELDS;
      if (isKemejaLenganPendek(outfit)) {
        fields = KEMEJA_PENDEK_FIELDS;
      } else if (isKemejaLenganPanjang(outfit)) {
        fields = KEMEJA_PANJANG_FIELDS;
      }
      const container = document.getElementById('measurement-fields')!;
      container.innerHTML = fields.map(([reactId, label, dbKey], i) => {
        const val = order[dbKey] ?? '—';
        return `
          <div class="space-y-2 relative">
            <div class="absolute left-[-1.75rem] top-[2.75rem] -translate-y-1/2 flex items-center justify-center w-6 h-6 rounded-full bg-indigo-600 text-white text-sm">${i + 1}</div>
            <label class="text-sm font-medium leading-none">${label} (cm)</label>
            <input value="${val}" disabled class="w-full h-12 rounded-md border-2 bg-slate-50 px-3 py-2 text-base" />
          </div>`;
      }).join('');

      fields.forEach(([reactId, , dbKey]) => {
        window.dispatchEvent(new CustomEvent('measurement-update', {
          detail: { id: reactId, value: String(order[dbKey] ?? '') },
        }));
      });
      (window as any).__lastOutfit = outfit;
      (window as any).__lastMeasurements = Object.fromEntries(
        fields.map(([reactId, , dbKey]) => [reactId, String(order[dbKey] ?? '')])
      );
      window.dispatchEvent(new CustomEvent('outfit-update', { detail: outfit }));
    }

    function renderStatusSelect(currentStatus: string) {
      const sel = document.getElementById('status-select') as HTMLSelectElement;
      const currentIdx = STATUS_FLOW.indexOf(currentStatus as OrderStatus);
      sel.innerHTML = STATUS_FLOW.map((s, i) => {
        const disabled = i < currentIdx ? 'disabled' : '';
        const selected = s === currentStatus ? 'selected' : '';
        return `<option value="${s}" ${selected} ${disabled}>${s}</option>`;
      }).join('');
    }

    async function loadOrder() {
      if (!orderId) return;

      let order: Record<string, any> | null = null;
      let customerName = '';
      let customerPhone = '';

      const local = await db.transaction.get(orderId);
      if (local) {
        order = local as Record<string, any>;
        const customer = await db.customer.get(local.customer_id);
        customerName = customer?.name ?? '';
        customerPhone = customer?.phone ?? '';
      } else if (navigator.onLine) {
        const { data: remoteTrx } = await trx.from('transaction').select('*').eq('id', orderId).single();
        if (remoteTrx) {
          order = remoteTrx as Record<string, any>;
          const { data: remoteCust } = await trx.from('customer').select('*').eq('id', order.customer_id).single();
          customerName = (remoteCust as any)?.name ?? '';
          customerPhone = (remoteCust as any)?.phone ?? '';
        }
      }

      if (!order) {
        document.getElementById('order-title')!.textContent = 'Pesanan tidak ditemukan';
        return;
      }

      document.getElementById('order-title')!.textContent = `Pesanan #${orderId} — ${customerName}`;
      (document.getElementById('field-name') as HTMLInputElement).value = customerName;
      (document.getElementById('field-phone') as HTMLInputElement).value = customerPhone;
      (document.getElementById('field-outfit') as HTMLInputElement).value = order.outfit_type ?? '';
      (document.getElementById('field-panjang-kain') as HTMLInputElement).value = order.panjang_kain ?? '';
      (document.getElementById('field-lebar-kain') as HTMLInputElement).value = order.lebar_kain ?? '';
      document.getElementById('field-cuci')!.textContent = order.cuci_sebelum_potong ? 'Ya' : 'Tidak';

      if (order.catatan) {
        document.getElementById('catatan-section')!.classList.remove('hidden');
        (document.getElementById('field-catatan') as HTMLTextAreaElement).value = order.catatan;
      }

      renderFields(order);
      renderStatusSelect(order.status);
    }

    document.getElementById('save-status-btn')!.addEventListener('click', async () => {
      const newStatus = (document.getElementById('status-select') as HTMLSelectElement).value;
      const btn = document.getElementById('save-status-btn') as HTMLButtonElement;
      btn.disabled = true;

      try {
        const local = await db.transaction.get(orderId);
        if (local) {
          await db.transaction.update(orderId, { status: newStatus as OrderStatus, synced: false });
        }
        if (navigator.onLine) {
          await trx.from('transaction').update({ status: newStatus }).eq('id', orderId);
          if (local) await db.transaction.update(orderId, { synced: true });
        }
        toast.success(`Status diperbarui ke "${newStatus}"`);
        renderStatusSelect(newStatus);
      } catch (err) {
        toast.error('Gagal menyimpan status. Silakan coba lagi.');
        console.error(err);
      } finally {
        btn.disabled = false;
      }
    });

    loadOrder();
  </script>
</AdminLayout>
