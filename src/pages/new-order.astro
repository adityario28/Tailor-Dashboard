---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Card, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Alert, AlertTitle, AlertDescription } from "@/components/ui/alert";
import { Combobox } from "@/components/ui/combobox";
import { Checkbox } from "@/components/ui/checkbox";
import MeasurementSketch from "@/components/measurementSketch";
import CustomerSearch from "@/components/CustomerSearch";
import SuccessDialog from "@/components/SuccessDialog";
const outfitOptions = [
  "Jas",
  "Kemeja Batik Lengan Pendek",
  "Kemeja Batik Lengan Panjang",
  "Kemeja Polos Lengan Pendek",
  "Kemeja Polos Lengan Panjang",
  "Celana",
];
---

<AdminLayout title="Input Ukuran Baru">
  <div class="container mx-auto space-y-6">
    <Alert>
      <AlertTitle>Tips Tablet!</AlertTitle>
      <AlertDescription
        >Sketsa di sebelah kanan menunjukkan lokasi pengukuran. Angka akan
        update secara otomatis saat Anda mengetik di formulir kiri.</AlertDescription
      >
    </Alert>

    <Card class="overflow-hidden border-2 shadow-xl">
      <CardHeader>
        <CardTitle>Pesanan Baru</CardTitle>
      </CardHeader>
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-slate-100"
      >
        {/* BAGIAN KIRI: Form Input */}
        <div class="px-8 pb-8 pt-6 space-y-6 bg-white">
          <form id="tailor-form" class="space-y-6">
            {/* Hidden fields for selected customer/preset IDs */}
            <input type="hidden" id="selectedCustomerId" value="" />
            <input type="hidden" id="selectedPresetId" value="" />

            <div class="grid grid-cols-1 gap-6">
              <div class="grid grid-cols-3 gap-3">
                <div class="col-span-2 space-y-2">
                  <Label
                    >Nama Pelanggan<span class="text-red-500">*</span></Label
                  >
                  <CustomerSearch client:only="react" />
                </div>
                <div class="space-y-2">
                  <Label>No. HP / WA</Label>
                  <Input
                    id="phone"
                    placeholder="08xx"
                    className="h-12 text-base border-2"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <Label
                  >Pilih Jenis Pakaian<span class="text-red-500">*</span></Label
                >
                <input type="hidden" id="outfitType" value="Jas" />
                <Combobox
                  client:only="react"
                  items={outfitOptions}
                  defaultValue="Jas"
                  placeholder="Pilih jenis pakaian"
                  className="h-12 border-2"
                  showClear={false}
                  eventName="outfit-changed"
                />
              </div>

              <div class="grid grid-cols-3 gap-4 items-end">
                <div class="space-y-2">
                  <Label
                    >P Kain (m)<span class="text-slate-400 font-normal text-xs">
                      otomatis</span
                    ></Label
                  >
                  <Input
                    id="panjangKain"
                    type="text"
                    inputmode="decimal"
                    placeholder="0,0"
                    className="h-12 border-2"
                  />
                </div>
                <div class="space-y-2">
                  <Label
                    >L Kain (m)<span class="text-slate-400 font-normal text-xs">
                      otomatis</span
                    ></Label
                  >
                  <Input
                    id="lebarKain"
                    type="text"
                    inputmode="decimal"
                    placeholder="0,0"
                    className="h-12 border-2"
                  />
                </div>
                <div class="flex flex-col items-center gap-2 pb-2">
                  <Label
                    for="cuciSebelumPotong"
                    class="whitespace-nowrap text-xs text-center"
                    >Perlu Dicuci Dulu?</Label
                  >
                  <Checkbox id="cuciSebelumPotong" client:load />
                </div>
              </div>
            </div>

            <hr />

            {/* Jas fields */}
            <div id="fields-jas" class="grid px-3 grid-cols-2 gap-x-9 gap-y-6">
              {
                [
                  ["panjangBadan",       "Panjang Badan"],
                  ["lebarBahu",          "Lebar Bahu"],
                  ["panjangLengan",      "Panjang Lengan"],
                  ["lingkarLengan",      "Lingkar Lengan"],
                  ["lingkarUjungLengan", "Lingkar Ujung Lengan"],
                  ["lingkarDada",        "Lingkar Dada"],
                  ["lingkarPerut",       "Lingkar Perut"],
                  ["lingkarPinggul",     "Lingkar Pinggul"],
                ].map(([id, label], i) => (
                  <div class="space-y-2 relative">
                    <div class="absolute left-[-1.75rem] top-[2.75rem] -translate-y-1/2 flex items-center justify-center w-6 h-6 rounded-full bg-indigo-600 text-white text-sm">
                      {i + 1}
                    </div>
                    <Label>{label} (cm)</Label>
                    <Input
                      id={id}
                      type="text"
                      inputmode="decimal"
                      placeholder="0,0"
                      className="h-12 border-2"
                    />
                  </div>
                ))
              }
            </div>

            {/* Kemeja lengan panjang fields */}
            <div id="fields-kemeja-panjang" class="hidden grid px-3 grid-cols-2 gap-x-9 gap-y-6">
              {
                [
                  ["lingkarLeher",      "Lingkar Leher"],
                  ["lebarBahu",         "Lebar Bahu"],
                  ["panjangLengan",     "Panjang Lengan"],
                  ["lingkarDada",       "Lingkar Dada"],
                  ["lingkarPerut",      "Lingkar Perut"],
                  ["panjangBadan",      "Panjang Badan"],
                  ["lingkarUjungLengan","Lingkar Ujung Lengan"],
                  ["lingkarPinggul",    "Lingkar Pinggul"],
                ].map(([id, label], i) => (
                  <div class="space-y-2 relative">
                    <div class="absolute left-[-1.75rem] top-[2.75rem] -translate-y-1/2 flex items-center justify-center w-6 h-6 rounded-full bg-indigo-600 text-white text-sm">
                      {i + 1}
                    </div>
                    <Label>{label} (cm)</Label>
                    <Input
                      id={id}
                      type="text"
                      inputmode="decimal"
                      placeholder="0,0"
                      className="h-12 border-2"
                    />
                  </div>
                ))
              }
            </div>

            {/* Kemeja lengan pendek fields */}
            <div id="fields-kemeja-pendek" class="hidden grid px-3 grid-cols-2 gap-x-9 gap-y-6">
              {
                [
                  ["lingkarLeher", "Lingkar Leher"],
                  ["lebarBahu", "Panjang Bahu"],
                  ["panjangLengan", "Panjang Lengan"],
                  ["lebarPundak", "Lebar Pundak"],
                  ["lingkarDada", "Lebar Dada"],
                  ["panjangBadan", "Panjang Badan"],
                  ["lingkarLengan", "Lingkar Lengan"],
                  ["lingkarPinggul", "Lebar Pinggul"],
                ].map(([id, label], i) => (
                  <div class="space-y-2 relative">
                    <div class="absolute left-[-1.75rem] top-[2.75rem] -translate-y-1/2 flex items-center justify-center w-6 h-6 rounded-full bg-indigo-600 text-white text-sm">
                      {i + 1}
                    </div>
                    <Label>{label} (cm)</Label>
                    <Input
                      id={id}
                      type="text"
                      inputmode="decimal"
                      placeholder="0,0"
                      className="h-12 border-2"
                    />
                  </div>
                ))
              }
            </div>

            <div class="grid grid-cols-4 gap-x-4 gap-y-6">
              {
                ["Furing", "Padding Tebal", "Padding Tipis", "Kancing"].map(
                  (label, i) => (
                    <div class="flex flex-col items-center gap-2">
                      <Label
                        for={`extra-${i}`}
                        class="whitespace-nowrap text-center text-xs"
                      >
                        {label}
                      </Label>
                      <Checkbox id={`extra-${i}`} client:load />
                    </div>
                  ),
                )
              }
            </div>

            {/* Save as preset option */}
            <div
              class="flex items-center gap-3 p-3 rounded-md bg-slate-50 border"
            >
              <Checkbox id="saveAsPreset" client:load />
              <div class="flex-1 flex items-center gap-3">
                <Label for="saveAsPreset" class="cursor-pointer"
                  >Simpan sebagai profil ukuran?</Label
                >
                <Input
                  id="presetName"
                  placeholder="Nama profil (cth: Jas Nikahan)"
                  className="h-9 border-2 flex-1"
                />
              </div>
            </div>

            <div class="space-y-2">
              <Label
                >Catatan<span class="text-slate-400 font-normal text-xs">
                  (opsional)</span
                ></Label
              >
              <textarea
                id="catatan"
                placeholder="Tambahkan catatan khusus..."
                class="w-full min-h-[80px] rounded-md border-2 border-input bg-background px-3 py-2 text-base resize-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
              ></textarea>
            </div>

            <div class="flex justify-end">
              <Button
                type="submit"
                class="h-14 px-10 text-lg font-bold bg-indigo-600 hover:bg-indigo-700"
              >
                Simpan Pesanan
              </Button>
            </div>
          </form>
        </div>

        {/* BAGIAN KANAN: Live Sketch */}
        <div
          class="p-6 bg-slate-50 flex flex-col justify-center items-center min-h-[600px]"
        >
          <p class="text-sm text-slate-500 mb-3 font-medium">
            Pratinjau Sketsa
          </p>
          <div class="w-full h-full" style="min-height: 500px;">
            <MeasurementSketch client:only="react" />
          </div>
        </div>
      </div>
    </Card>
  </div>

  {/* Success Dialog */}
  <SuccessDialog client:only="react" />

  <script>
    import {
      db,
      syncCustomer,
      syncPreset,
      syncTransaction,
      syncPending,
    } from "@/lib/db";
    import type { Customer, PresetCustomer } from "@/lib/db";
    import { toast } from "sonner";
    import { trx } from "@/lib/supabase";

    window.addEventListener("online", () => syncPending());
    syncPending();

    const form = document.getElementById("tailor-form") as HTMLFormElement;
    const g = (id: string) => document.getElementById(id) as HTMLInputElement;
    const parseVal = (val: string) => parseFloat(val.replace(",", ".")) || 0;

    const PANJANG_KAIN_DEFAULT: Record<string, number> = {
      Jas: 3,
      "Kemeja Batik Lengan Pendek": 2,
      "Kemeja Batik Lengan Panjang": 3,
      "Kemeja Polos Lengan Pendek": 1.25,
      "Kemeja Polos Lengan Panjang": 1.5,
      Celana: 1.25,
    };

    const LEBAR_KAIN_DEFAULT: Record<string, number> = {
      Jas: 1.5,
      "Kemeja Batik Lengan Pendek": 1.15,
      "Kemeja Batik Lengan Panjang": 1.15,
      "Kemeja Polos Lengan Pendek": 1.5,
      "Kemeja Polos Lengan Panjang": 1.5,
      Celana: 1.5,
    };

    const REQUIRED = [
      "panjangBadan",
      "lebarBahu",
      "panjangLengan",
      "lingkarLengan",
      "lingkarUjungLengan",
      "lingkarDada",
      "lingkarPerut",
      "lingkarPinggul",
    ];

    const REQUIRED_KEMEJA_PANJANG = [
      "lingkarLeher",
      "lebarBahu",
      "panjangLengan",
      "lingkarDada",
      "lingkarPerut",
      "panjangBadan",
      "lingkarUjungLengan",
      "lingkarPinggul",
    ];

    const REQUIRED_KEMEJA_PENDEK = [
      "lingkarLeher",
      "lebarBahu",
      "panjangLengan",
      "lebarPundak",
      "lingkarDada",
      "panjangBadan",
      "lingkarLengan",
      "lingkarPinggul",
    ];

    function isKemejaLenganPendek(outfit: string) {
      return outfit.toLowerCase().includes('kemeja') && outfit.toLowerCase().includes('pendek');
    }

    function isKemejaLenganPanjang(outfit: string) {
      return outfit.toLowerCase().includes('kemeja') && outfit.toLowerCase().includes('panjang');
    }

    function getActiveRequired(outfit: string) {
      if (isKemejaLenganPendek(outfit)) return REQUIRED_KEMEJA_PENDEK;
      if (isKemejaLenganPanjang(outfit)) return REQUIRED_KEMEJA_PANJANG;
      return REQUIRED;
    }

    function switchFieldSet(outfit: string) {
      const jasEl = document.getElementById('fields-jas')!;
      const panjangEl = document.getElementById('fields-kemeja-panjang')!;
      const pendekEl = document.getElementById('fields-kemeja-pendek')!;
      const show = (el: HTMLElement) => { el.classList.remove('hidden'); el.classList.add('grid'); };
      const hide = (el: HTMLElement) => { el.classList.add('hidden'); el.classList.remove('grid'); };
      if (isKemejaLenganPendek(outfit)) {
        hide(jasEl); hide(panjangEl); show(pendekEl);
      } else if (isKemejaLenganPanjang(outfit)) {
        hide(jasEl); show(panjangEl); hide(pendekEl);
      } else {
        show(jasEl); hide(panjangEl); hide(pendekEl);
      }
    }

    function updateKainDefaults(outfit: string) {
      console.log(
        "new-order.astro: updateKainDefaults called for outfit:",
        outfit,
      );
      const pEl = g("panjangKain");
      const lEl = g("lebarKain");
      console.log(
        "new-order.astro: updateKainDefaults found elements:",
        !!pEl,
        !!lEl,
      );
      if (pEl) {
        pEl.value = String(PANJANG_KAIN_DEFAULT[outfit] ?? "");
        console.log(
          "new-order.astro: updateKainDefaults set panjangKain value to:",
          pEl.value,
        );
      }
      if (lEl) {
        lEl.value = String(LEBAR_KAIN_DEFAULT[outfit] ?? "");
        console.log(
          "new-order.astro: updateKainDefaults set lebarKain value to:",
          lEl.value,
        );
      }
    }
    (window as any).__lastOutfit = 'Jas';
    updateKainDefaults("Jas");

    // Fill form when existing customer + preset selected
    window.addEventListener("customer-selected", (e) => {
      const { isNew, customer, preset } = (e as CustomEvent).detail;
      if (isNew) {
        form.reset();
        g("selectedCustomerId").value = "";
        g("selectedPresetId").value = "";
        updateKainDefaults(g("outfitType").value || "Jas");
        return;
      }
      g("selectedCustomerId").value = String(customer.id);
      g("name").value = customer.name ?? "";
      g("phone").value = customer.phone ?? "";

      function setFieldValue(id: string, value: string) {
        const elements = document.querySelectorAll(`#${id}`);
        elements.forEach((el) => {
          if (el instanceof HTMLInputElement) {
            el.value = value;
          }
        });
        window.dispatchEvent(
          new CustomEvent("measurement-update", {
            detail: { id: id, value: value },
          }),
        );
      }

      if (preset) {
        g("selectedPresetId").value = String(preset.id ?? "");
        g("outfitType").value = preset.outfit_type ?? "";
        if (preset.panjang_kain) {
          g("panjangKain").value = String(preset.panjang_kain);
        }
        if (preset.lebar_kain) {
          g("lebarKain").value = String(preset.lebar_kain);
        }
        // Set cuci_sebelum_potong checkbox
        const cuciEl = document.getElementById(
          "cuciSebelumPotong",
        ) as HTMLElement;
        const cuciShouldBeChecked = !!preset.cuci_sebelum_potong;
        const cuciIsChecked = cuciEl?.dataset.state === "checked";
        if (cuciEl && cuciShouldBeChecked !== cuciIsChecked) cuciEl.click();
        const allFields = [...new Set([...REQUIRED, ...REQUIRED_KEMEJA_PANJANG, ...REQUIRED_KEMEJA_PENDEK])];
        allFields.forEach((field) => {
          const key = field
            .replace(/([A-Z])/g, "_$1")
            .toLowerCase() as keyof PresetCustomer;
          if (preset[key] != null) {
            setFieldValue(field, String(preset[key]));
          }
        });
        window.dispatchEvent(
          new CustomEvent("outfit-update", { detail: preset.outfit_type }),
        );
        switchFieldSet(preset.outfit_type ?? "");
      } else {
        // Ukuran Baru: clear measurement fields, keep customer info
        g("selectedPresetId").value = "";
        [...new Set([...REQUIRED, ...REQUIRED_KEMEJA_PANJANG, ...REQUIRED_KEMEJA_PENDEK])].forEach((field) => {
          setFieldValue(field, "");
        });
      }
    });

    // Make setFieldValue globally accessible for other event handlers
    function setFieldValue(id: string, value: string) {
      const elements = document.querySelectorAll(`#${id}`);
      elements.forEach((el) => {
        if (el instanceof HTMLInputElement) {
          el.value = value;
        }
      });
      window.dispatchEvent(
        new CustomEvent("measurement-update", {
          detail: { id: id, value: value },
        }),
      );
    }

    form?.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      if (target.classList.contains("field-error")) {
        target.classList.remove("field-error");
        target.style.removeProperty("border-color");
        target.style.removeProperty("box-shadow");
      }
      if (target.id) {
        setFieldValue(target.id, target.value);
      } else {
        window.dispatchEvent(
          new CustomEvent("measurement-update", {
            detail: { id: target.id, value: target.value },
          }),
        );
      }
    });

    form?.addEventListener("focusin", (e) => {
      const id = (e.target as HTMLElement).id;
      window.dispatchEvent(
        new CustomEvent("measurement-focus", { detail: id }),
      );
    });
    form?.addEventListener("focusout", () => {
      window.dispatchEvent(
        new CustomEvent("measurement-focus", { detail: null }),
      );
    });

    window.addEventListener("outfit-changed", (e) => {
      const val = (e as CustomEvent).detail;
      const el = g("outfitType");
      if (el) el.value = val;
      (window as any).__lastOutfit = val;
      window.dispatchEvent(new CustomEvent("outfit-update", { detail: val }));
      updateKainDefaults(val);
      switchFieldSet(val);
    });

    function highlightFields(ids: string[]) {
      // Clear previous highlights
      document.querySelectorAll(".field-error").forEach((el) => {
        el.classList.remove("field-error");
        (el as HTMLElement).style.removeProperty("border-color");
        (el as HTMLElement).style.removeProperty("box-shadow");
      });
      if (ids.length === 0) return;
      const activeSection = document.querySelector('[id^="fields-"]:not(.hidden)') as HTMLElement;
      ids.forEach((id, i) => {
        const el = (activeSection?.querySelector(`#${id}`) ?? document.getElementById(id)) as HTMLElement | null;
        if (!el) return;
        el.classList.add("field-error");
        el.style.borderColor = "rgb(239,68,68)";
        el.style.boxShadow = "0 0 0 2px rgba(239,68,68,0.3)";
        if (i === 0) el.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      highlightFields([]);
      const outfitValue = g("outfitType").value;
      if (!outfitValue) {
        toast.error("Pilih jenis pakaian terlebih dahulu.");
        const outfitEl = document.getElementById("outfitType")?.closest(".space-y-2") as HTMLElement | null;
        if (outfitEl) outfitEl.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      const activeSection = document.querySelector('[id^="fields-"]:not(.hidden)') as HTMLElement;
      const empty = getActiveRequired(outfitValue).filter((id) => {
        const el = (activeSection?.querySelector(`#${id}`) ?? document.getElementById(id)) as HTMLInputElement | null;
        return !parseVal(el?.value ?? "");
      });
      if (empty.length > 0) {
        toast.error("Harap isi semua 8 field ukuran sebelum menyimpan.");
        highlightFields(empty);
        return;
      }

      const cuciEl = document.getElementById(
        "cuciSebelumPotong",
      ) as HTMLInputElement;
      const cuci =
        cuciEl?.dataset.state === "checked" || cuciEl?.checked || false;

      // Read from the active (visible) section to avoid duplicate-id issue
      const gActive = (id: string): HTMLInputElement => {
        return (activeSection?.querySelector(`#${id}`) ?? document.getElementById(id)) as HTMLInputElement;
      };

      const measurements = {
        outfit_type: outfitValue,
        panjang_kain: parseVal(g("panjangKain").value),
        lebar_kain: parseVal(g("lebarKain").value),
        cuci_sebelum_potong: cuci,
        panjang_badan: parseVal(gActive("panjangBadan").value),
        lebar_bahu: parseVal(gActive("lebarBahu").value),
        panjang_lengan: parseVal(gActive("panjangLengan").value),
        lingkar_lengan: parseVal(gActive("lingkarLengan").value),
        lingkar_ujung_lengan: parseVal(gActive("lingkarUjungLengan").value),
        lingkar_dada: parseVal(gActive("lingkarDada").value),
        lingkar_perut: parseVal(gActive("lingkarPerut").value),
        lingkar_pinggul: parseVal(gActive("lingkarPinggul").value),
        lingkar_leher: parseVal(gActive("lingkarLeher")?.value ?? "") || undefined,
        lebar_pundak: parseVal(gActive("lebarPundak")?.value ?? "") || undefined,
        catatan: (document.getElementById("catatan") as HTMLTextAreaElement)
          .value,
      };

      try {
        // 1. Resolve customer_id
        let customerId = parseInt(g("selectedCustomerId").value) || 0;
        let supabaseCustomerId: number | null = null;
        if (!customerId) {
          const name = g("name").value.trim();
          if (!name) {
            toast.error("Masukkan nama pelanggan.");
            return;
          }
          const newCustomer: Customer = {
            name,
            phone: g("phone").value.trim() || undefined,
            total_trx: 0,
            synced: false,
          };
          customerId = (await db.customer.add(newCustomer)) as number;
          supabaseCustomerId = await syncCustomer({
            ...newCustomer,
            id: customerId,
          });
        } else if (navigator.onLine) {
          // Existing customer: look up their Supabase ID by name
          const localCustomer = await db.customer.get(customerId);
          if (localCustomer?.name) {
            const { data } = await trx
              .from("customer")
              .select("id")
              .eq("name", localCustomer.name)
              .single();
            if (data?.id) supabaseCustomerId = data.id as number;
          }
        }

        // 2. Optionally save preset
        const savePresetEl = document.getElementById(
          "saveAsPreset",
        ) as HTMLInputElement;
        const savePreset =
          savePresetEl?.dataset.state === "checked" ||
          savePresetEl?.checked ||
          false;
        let presetId = parseInt(g("selectedPresetId").value) || undefined;
        let supabasePresetId: number | undefined;

        if (savePreset && !presetId) {
          const presetName = g("presetName").value.trim() || outfitValue;
          const newPreset = {
            customer_id: customerId,
            preset_name: presetName,
            ...measurements,
            synced: false,
          };
          presetId = (await db.preset_customer.add(newPreset)) as number;
          const spid = await syncPreset(
            { ...newPreset, id: presetId },
            supabaseCustomerId ?? undefined,
          );
          supabasePresetId = spid ?? undefined;
        }

        // 3. Save transaction (measurements copied in)
        const status = cuci ? "Cuci Bahan" : "Potong Bahan";
        const newTrx = {
          customer_id: customerId,
          preset_id: presetId,
          ...measurements,
          status,
          synced: false,
        } as import("@/lib/db").Transaction;
        const trxId = (await db.transaction.add(newTrx)) as number;
        await syncTransaction(
          { ...newTrx, id: trxId },
          supabaseCustomerId ?? undefined,
          supabasePresetId,
        );

        // printReceipt({
        //   ...measurements,
        //   id: trxId,
        //   name: g("name").value,
        //   status,
        // });
        form.reset();
        g("selectedCustomerId").value = "";
        g("selectedPresetId").value = "";
        updateKainDefaults("Jas");
        window.dispatchEvent(new CustomEvent("measurement-reset"));
        window.dispatchEvent(new CustomEvent("order-success"));
      } catch (err) {
        console.error(err);
        toast.error("Gagal menyimpan data.");
      }
    });

