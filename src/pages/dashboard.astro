---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardContent } from "@/components/ui/card";
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-950">
          Dashboard
        </h1>
        <p class="text-slate-500 mt-1">Selamat datang di Tailor App</p>
      </div>
      <a href="/new-order">
        <Button
          className="h-12 px-6 text-base font-semibold bg-indigo-600 hover:bg-indigo-700 gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 5v14M5 12h14"></path>
          </svg>
          Tambah Pesanan
        </Button>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Total Pesanan</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-slate-900" id="total-orders">
            —
          </p></CardContent
        >
      </Card>
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Sedang Dikerjakan</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-amber-500" id="orders-active">
            —
          </p></CardContent
        >
      </Card>
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Siap Diambil</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-green-600" id="orders-done">
            —
          </p></CardContent
        >
      </Card>
    </div>

    <Card>
      <CardHeader><CardTitle>Daftar Pesanan</CardTitle></CardHeader>
      <CardContent>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-slate-500 text-left">
              <th class="pb-3 font-medium">Nama Pelanggan</th>
              <th class="pb-3 font-medium">Jenis</th>
              <th class="pb-3 font-medium">Tanggal</th>
              <th class="pb-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody id="orders-tbody">
            <tr
              ><td colspan="5" class="py-8 text-center text-slate-400"
                >Memuat data...</td
              ></tr
            >
          </tbody>
        </table>
      </CardContent>
    </Card>
  </div>

  <script>
    import { db, STATUS_FLOW } from "@/lib/db";
    import { trx } from "@/lib/supabase";
    import type { OrderStatus, Transaction, Customer } from "@/lib/db";

    const STATUS_COLORS: Record<OrderStatus, string> = {
      "Cuci Bahan": "bg-blue-100 text-blue-700",
      "Potong Bahan": "bg-orange-100 text-orange-700",
      Jahit: "bg-purple-100 text-purple-700",
      Finishing: "bg-yellow-100 text-yellow-700",
      "Siap Diambil": "bg-green-100 text-green-700",
    };

    async function loadDashboard() {
      type Row = Transaction & { id: number; _customerName: string; _source: 'local' | 'remote' };

      const [localTrx, localCustomers] = await Promise.all([
        db.transaction.toArray(),
        db.customer.toArray(),
      ]);

      const localCustomerMap = new Map(localCustomers.map(c => [c.id, c]));

      // Start with all local records
      const rows = new Map<string, Row>();

      for (const t of localTrx) {
        const key = `local-${t.id}`;
        rows.set(key, {
          ...t,
          id: t.id!,
          _customerName: localCustomerMap.get(t.customer_id)?.name ?? 'Pelanggan',
          _source: 'local',
        });
      }

      // Fetch Supabase and union — for synced local records, Supabase wins (has latest status)
      if (navigator.onLine) {
        const [{ data: remoteTrx }, { data: remoteCustomers }] = await Promise.all([
          trx.from('transaction').select('*'),
          trx.from('customer').select('*'),
        ]);
        const remoteCustomerMap = new Map((remoteCustomers as Customer[] ?? []).map(c => [c.id, c]));

        for (const t of (remoteTrx as Transaction[] ?? [])) {
          // Check if a local synced record corresponds to this Supabase record.
          // Since Dexie IDs ≠ Supabase IDs, match by customer name + outfit_type + panjang_kain as fingerprint.
          const customerName = remoteCustomerMap.get(t.customer_id)?.name ?? 'Pelanggan';
          const matchingLocalKey = [...rows.entries()].find(([, r]) => {
            return r._source === 'local' && r.synced &&
              localCustomerMap.get(r.customer_id)?.name === customerName &&
              r.outfit_type === t.outfit_type &&
              r.panjang_kain === t.panjang_kain &&
              r.panjang_badan === t.panjang_badan;
          })?.[0];

          if (matchingLocalKey) {
            // Replace local copy with Supabase version (has latest status)
            const localRow = rows.get(matchingLocalKey)!;
            rows.delete(matchingLocalKey);
            rows.set(`remote-${t.id}`, { ...t, id: t.id!, _customerName: customerName, _source: 'remote' });
          } else {
            // Supabase-only record (not in Dexie), add it
            const existsRemote = [...rows.keys()].some(k => k.startsWith('remote-') && rows.get(k)!.id === t.id);
            if (!existsRemote) {
              rows.set(`remote-${t.id}`, { ...t, id: t.id!, _customerName: customerName, _source: 'remote' });
            }
          }
        }
      }

      const transactions = [...rows.values()];
      const done = transactions.filter(t => t.status === "Siap Diambil");
      const active = transactions.filter(t => t.status !== "Siap Diambil");

      document.getElementById("total-orders")!.textContent = String(transactions.length);
      document.getElementById("orders-active")!.textContent = String(active.length);
      document.getElementById("orders-done")!.textContent = String(done.length);

      const tbody = document.getElementById("orders-tbody")!;
      if (transactions.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="py-8 text-center text-slate-400">Belum ada pesanan.</td></tr>`;
        return;
      }

      const sorted = [...transactions].sort((a, b) => (b.id || 0) - (a.id || 0));
      tbody.innerHTML = sorted
        .map((t) => {
          const colorClass = STATUS_COLORS[t.status] ?? "";
          const currentIdx = STATUS_FLOW.indexOf(t.status as OrderStatus);
          // Only show statuses from current status onward (forward-only)
          const visibleStatuses = currentIdx >= 0 ? STATUS_FLOW.slice(currentIdx) : STATUS_FLOW;
          const options = visibleStatuses.map(s =>
            `<option value="${s}" ${s === t.status ? 'selected' : ''}>${s}</option>`
          ).join('');

          return `
          <tr class="border-b last:border-0 hover:bg-slate-50 cursor-pointer" onclick="window.location.href='/order?id=${t.id}&src=${t._source}'">
            <td class="py-3 font-medium text-slate-900">${t._customerName}</td>
            <td class="py-3 text-slate-600">${t.outfit_type || 'Pakaian'}</td>
            <td class="py-3 text-slate-500">Baru</td>
            <td class="py-3">
              <select data-id="${t.id}" data-source="${t._source}" class="status-select text-xs font-semibold px-2 py-1.5 rounded-full border-0 cursor-pointer ${colorClass}">
                ${options}
              </select>
            </td>
          </tr>`;
        })
        .join("");

      // Add event listeners to status-select dropdowns
      tbody.querySelectorAll<HTMLSelectElement>('.status-select').forEach(sel => {
        sel.addEventListener('change', async (e) => {
          e.stopPropagation();
          const trId = Number(sel.dataset.id);
          const source = sel.dataset.source;
          const newStatus = sel.value as OrderStatus;

          try {
            if (source === 'local') {
              await db.transaction.update(trId, { status: newStatus, synced: false });
            }
            if (navigator.onLine) {
              await trx.from('transaction').update({ status: newStatus }).eq('id', trId);
              if (source === 'local') {
                await db.transaction.update(trId, { synced: true });
              }
            }
            loadDashboard();
          } catch (err) {
            console.error("Error updating status on dashboard:", err);
          }
        });

        // Prevent clicking/changing the dropdown from navigating to order details page
        sel.addEventListener('click', (e) => {
          e.stopPropagation();
        });
        sel.addEventListener('mousedown', (e) => {
          e.stopPropagation();
        });
      });
    }

    loadDashboard();
  </script>
</AdminLayout>
