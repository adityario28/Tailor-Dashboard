---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardContent } from "@/components/ui/card";
import OrdersTable from "@/components/OrdersTable";
import DashboardMetrics from "@/components/DashboardMetrics";
import { Skeleton } from "@/components/ui/skeleton";
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-950">
          Dashboard
        </h1>
        <p class="text-slate-500 mt-1">Selamat datang di Tailor App</p>
      </div>
      <a href="/new-order">
        <Button
          className="h-12 px-6 text-base font-semibold bg-indigo-600 hover:bg-indigo-700 gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 5v14M5 12h14"></path>
          </svg>
          Tambah Pesanan
        </Button>
      </a>
    </div>

    <!-- Skeleton placeholder for metrics (shows immediately) -->
    <div id="metrics-skeleton" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Card>
        <CardHeader>
          <CardTitle class="text-sm font-medium text-slate-500">
            Total Pesanan
          </CardTitle>
        </CardHeader>
        <CardContent>
          <Skeleton className="h-10 w-16" />
        </CardContent>
      </Card>
      <Card>
        <CardHeader>
          <CardTitle class="text-sm font-medium text-slate-500">
            Sedang Dikerjakan
          </CardTitle>
        </CardHeader>
        <CardContent>
          <Skeleton className="h-10 w-16" />
        </CardContent>
      </Card>
      <Card>
        <CardHeader>
          <CardTitle class="text-sm font-medium text-slate-500">
            Siap Diambil
          </CardTitle>
        </CardHeader>
        <CardContent>
          <Skeleton className="h-10 w-16" />
        </CardContent>
      </Card>
    </div>

    <!-- React component (hidden until loaded, then replaces skeleton) -->
    <div id="metrics-real" style="display: none;">
      <DashboardMetrics client:only="react" />
    </div>

    <!-- Skeleton for table -->
    <Card id="table-skeleton">
      <CardHeader><CardTitle>Daftar Pesanan</CardTitle></CardHeader>
      <CardContent>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-slate-500 text-left">
              <th class="pb-3 font-medium">Nama Pelanggan</th>
              <th class="pb-3 font-medium">Jenis</th>
              <th class="pb-3 font-medium">Tanggal</th>
              <th class="pb-3 font-medium">Status Pembayaran</th>
              <th class="pb-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody>
            {[...Array(5)].map((_, i) => (
              <tr key={i} class="border-b">
                <td class="py-3"><Skeleton className="h-5 w-32" /></td>
                <td class="py-3"><Skeleton className="h-5 w-40" /></td>
                <td class="py-3"><Skeleton className="h-5 w-28" /></td>
                <td class="py-3"><Skeleton className="h-6 w-20 rounded-full" /></td>
                <td class="py-3"><Skeleton className="h-6 w-24 rounded-full" /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </CardContent>
    </Card>

    <!-- React table (hidden until loaded) -->
    <div id="table-real" style="display: none;">
      <Card>
        <CardHeader><CardTitle>Daftar Pesanan</CardTitle></CardHeader>
        <CardContent>
          <OrdersTable client:only="react" />
        </CardContent>
      </Card>
    </div>
  </div>

  <script>
    // Show React components and hide skeletons once loaded
    document.addEventListener('DOMContentLoaded', () => {
      // Wait a bit for React to hydrate
      setTimeout(() => {
        const metricsSkeleton = document.getElementById('metrics-skeleton');
        const metricsReal = document.getElementById('metrics-real');
        const tableSkeleton = document.getElementById('table-skeleton');
        const tableReal = document.getElementById('table-real');

        if (metricsSkeleton && metricsReal) {
          metricsSkeleton.style.display = 'none';
          metricsReal.style.display = 'block';
        }

        if (tableSkeleton && tableReal) {
          tableSkeleton.style.display = 'none';
          tableReal.style.display = 'block';
        }
      }, 100);
    });
  </script>
</AdminLayout>
