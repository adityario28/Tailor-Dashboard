---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { Card, CardHeader, CardTitle, CardContent } from "@/components/ui/card";
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-950">
          Dashboard
        </h1>
        <p class="text-slate-500 mt-1">Selamat datang di Tailor App</p>
      </div>
      <a href="/new-order">
        <Button
          className="h-12 px-6 text-base font-semibold bg-indigo-600 hover:bg-indigo-700 gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 5v14M5 12h14"></path>
          </svg>
          Tambah Pesanan
        </Button>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Total Pesanan</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-slate-900" id="total-orders">
            —
          </p></CardContent
        >
      </Card>
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Sedang Dikerjakan</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-amber-500" id="orders-active">
            —
          </p></CardContent
        >
      </Card>
      <Card>
        <CardHeader
          ><CardTitle class="text-sm font-medium text-slate-500"
            >Siap Diambil</CardTitle
          ></CardHeader
        >
        <CardContent
          ><p class="text-3xl font-bold text-green-600" id="orders-done">
            —
          </p></CardContent
        >
      </Card>
    </div>

    <Card>
      <CardHeader><CardTitle>Daftar Pesanan</CardTitle></CardHeader>
      <CardContent>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-slate-500 text-left">
              <th class="pb-3 font-medium">Nama Pelanggan</th>
              <th class="pb-3 font-medium">Jenis</th>
              <th class="pb-3 font-medium">Tanggal</th>
              <th class="pb-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody id="orders-tbody">
            <tr
              ><td colspan="5" class="py-8 text-center text-slate-400"
                >Memuat data...</td
              ></tr
            >
          </tbody>
        </table>
      </CardContent>
    </Card>
  </div>

  <script>
    import { db, STATUS_FLOW } from "@/lib/db";
    import { trx } from "@/lib/supabase";
    import type { OrderStatus, Transaction, Customer } from "@/lib/db";

    const STATUS_COLORS: Record<OrderStatus, string> = {
      "Cuci Bahan": "bg-blue-100 text-blue-700",
      "Potong Bahan": "bg-orange-100 text-orange-700",
      Jahit: "bg-purple-100 text-purple-700",
      Finishing: "bg-yellow-100 text-yellow-700",
      "Siap Diambil": "bg-green-100 text-green-700",
    };

    async function loadDashboard() {
      // Load from Dexie
      const [localTrx, localCustomers] = await Promise.all([
        db.transaction.toArray(),
        db.customer.toArray(),
      ]);

      let transactions: (Transaction & { id: number; _customerName: string })[] = [];

      if (localTrx.length > 0) {
        // Dexie has data — merge with Supabase (Supabase wins for synced records)
        const customerMap = new Map(localCustomers.map((c) => [c.id, c]));

        // Fetch Supabase versions of synced transactions
        let remoteMap = new Map<number, Transaction>();
        if (navigator.onLine) {
          const syncedIds = localTrx.filter(t => t.synced).map(t => t.id!);
          if (syncedIds.length > 0) {
            const { data } = await trx.from('transaction').select('*').in('id', syncedIds as number[]);
            // Note: Supabase IDs ≠ Dexie IDs for synced records, match by customer+outfit
            // Instead fetch all and match by Dexie id stored in synced flag
            if (data) {
              // We can't directly match by Dexie ID since Supabase has its own IDs.
              // Use Supabase as authoritative for status only — fetch all and build name map.
              (data as Transaction[]).forEach(r => {
                if (r.id) remoteMap.set(r.id, r);
              });
            }
          }
        }

        transactions = localTrx.map(t => {
          const c = customerMap.get(t.customer_id);
          // For synced records, prefer Supabase status if available
          const remote = t.synced ? remoteMap.get(t.id!) : undefined;
          return {
            ...(remote ?? t),
            id: t.id!,
            _customerName: c?.name ?? 'Pelanggan',
          };
        });
      } else if (navigator.onLine) {
        // Dexie empty — load everything from Supabase
        const [{ data: remoteTrx }, { data: remoteCustomers }] = await Promise.all([
          trx.from('transaction').select('*'),
          trx.from('customer').select('*'),
        ]);
        const customerMap = new Map((remoteCustomers as Customer[] ?? []).map(c => [c.id, c]));
        transactions = (remoteTrx as Transaction[] ?? []).map(t => ({
          ...t,
          id: t.id!,
          _customerName: customerMap.get(t.customer_id)?.name ?? 'Pelanggan',
        }));
      }

      const done = transactions.filter(t => t.status === "Siap Diambil");
      const active = transactions.filter(t => t.status !== "Siap Diambil");

      document.getElementById("total-orders")!.textContent = String(transactions.length);
      document.getElementById("orders-active")!.textContent = String(active.length);
      document.getElementById("orders-done")!.textContent = String(done.length);

      const tbody = document.getElementById("orders-tbody")!;
      if (transactions.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="py-8 text-center text-slate-400">Belum ada pesanan.</td></tr>`;
        return;
      }

      const sorted = [...transactions].sort((a, b) => (b.id || 0) - (a.id || 0));
      tbody.innerHTML = sorted
        .map((t) => {
          const currentIdx = STATUS_FLOW.indexOf(t.status);
          const options = STATUS_FLOW.slice(currentIdx)
            .map(s => `<option value="${s}" ${s === t.status ? "selected" : ""}>${s}</option>`)
            .join("");
          const colorClass = STATUS_COLORS[t.status] ?? "";
          return `
          <tr class="border-b last:border-0 hover:bg-slate-50">
            <td class="py-3 font-medium text-slate-900">${t._customerName}</td>
            <td class="py-3 text-slate-600">${t.outfit_type || 'Pakaian'}</td>
            <td class="py-3 text-slate-500">Baru</td>
            <td class="py-3">
              <select data-id="${t.id}" class="status-select text-xs font-medium px-2 py-1 rounded-full border-0 cursor-pointer ${colorClass}">
                ${options}
              </select>
            </td>
          </tr>`;
        })
        .join("");

      tbody.querySelectorAll<HTMLSelectElement>(".status-select").forEach((sel) => {
        sel.addEventListener("change", async () => {
          const id = Number(sel.dataset.id);
          const newStatus = sel.value as OrderStatus;
          // Update Dexie if record exists locally
          const local = await db.transaction.get(id);
          if (local) {
            await db.transaction.update(id, { status: newStatus, synced: false });
          }
          // Update Supabase directly
          if (navigator.onLine) {
            await trx.from('transaction').update({ status: newStatus }).eq('id', id);
            if (local) await db.transaction.update(id, { synced: true });
          }
          loadDashboard();
        });
      });
    }

    loadDashboard();
  </script>
</AdminLayout>
