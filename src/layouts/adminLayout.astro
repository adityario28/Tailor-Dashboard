---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '@/styles/global.css';
import { Toaster } from '@/components/ui/sonner';
---
<html lang="en">
  <head></head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <div class="flex min-h-screen">
      <aside id="sidebar" class="relative w-64 bg-white border-r hidden md:flex flex-col sticky top-0 h-screen transition-[width] duration-300 overflow-hidden">

        {/* Header: logo + toggle button */}
        <div class="flex items-center justify-between px-4 h-16 border-b shrink-0">
          <span id="sidebar-title" class="text-lg font-bold text-indigo-600 whitespace-nowrap overflow-hidden">Tailor App</span>
          <button
            id="sidebar-toggle"
            class="ml-auto flex items-center justify-center w-8 h-8 rounded-md text-slate-500 hover:bg-slate-100 hover:text-indigo-600 transition-colors shrink-0"
            aria-label="Toggle sidebar"
          >
            {/* PanelLeft — lucide/shadcn sidebar toggle icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/>
              <path d="M9 3v18"/>
            </svg>
          </button>
        </div>

        {/* Nav */}
        <nav class="px-2 py-4 space-y-1">
          <a href="/dashboard" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg bg-indigo-50 text-indigo-700 font-medium">
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            <span class="nav-label whitespace-nowrap">Dashboard</span>
          </a>
          <a href="/customers" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 hover:bg-slate-100">
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="nav-label whitespace-nowrap">Customers</span>
          </a>
        </nav>
      </aside>

      <main class="flex-1 p-4 md:p-10">
        <div class="max-w-6xl mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('sidebar')!;
      const title = document.getElementById('sidebar-title')!;
      const labels = sidebar.querySelectorAll<HTMLElement>('.nav-label');

      function applyCollapsed(collapsed: boolean) {
        if (collapsed) {
          sidebar.style.width = '56px';
          title.style.display = 'none';
          labels.forEach(el => el.style.display = 'none');
        } else {
          sidebar.style.width = '256px';
          title.style.display = '';
          labels.forEach(el => el.style.display = '');
        }
      }

      // Restore persisted state immediately (no transition flash)
      let collapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      applyCollapsed(collapsed);

      document.getElementById('sidebar-toggle')!.addEventListener('click', () => {
        collapsed = !collapsed;
        localStorage.setItem('sidebar-collapsed', String(collapsed));
        applyCollapsed(collapsed);
      });
    </script>
    <Toaster client:only="react" />
  </body>
</html>
