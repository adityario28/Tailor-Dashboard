---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '@/styles/global.css';
import { Toaster } from '@/components/ui/sonner';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/dashboard';
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');

const navClass = (href: string) =>
  `nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium transition-colors ${
    isActive(href)
      ? 'bg-indigo-50 text-indigo-700'
      : 'text-slate-600 hover:bg-slate-100'
  }`;
---
<html lang="en">
  <head></head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <div class="flex min-h-screen">
      <aside id="sidebar" class="relative w-64 bg-white border-r hidden md:flex flex-col sticky top-0 h-screen transition-[width] duration-300 overflow-hidden">

        {/* Header: logo + toggle button */}
        <div class="flex items-center justify-between px-4 h-16 border-b shrink-0">
          <span id="sidebar-title" class="text-lg font-bold text-indigo-600 whitespace-nowrap overflow-hidden">Tailor App</span>
          <button
            id="sidebar-toggle"
            class="ml-auto flex items-center justify-center w-8 h-8 rounded-md text-slate-500 hover:bg-slate-100 hover:text-indigo-600 transition-colors shrink-0"
            aria-label="Toggle sidebar"
          >
            {/* PanelLeft — lucide/shadcn sidebar toggle icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/>
              <path d="M9 3v18"/>
            </svg>
          </button>
        </div>

        {/* Nav */}
        <nav class="px-2 py-4 space-y-1 flex-1">
          <a href="/dashboard" class={navClass('/dashboard')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            <span class="nav-label whitespace-nowrap">Dashboard</span>
          </a>
          <a href="/customers" class={navClass('/customers')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="nav-label whitespace-nowrap">Customers</span>
          </a>
          <a href="/materials" class={navClass('/materials')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            <span class="nav-label whitespace-nowrap">Bahan & Stok</span>
          </a>
          <a href="/expenses" class={navClass('/expenses')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="nav-label whitespace-nowrap">Pengeluaran</span>
          </a>
          <a href="/reports" class={navClass('/reports')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            <span class="nav-label whitespace-nowrap">Laporan</span>
          </a>
        </nav>

        {/* Bottom menu */}
        <div class="px-2 pb-4 border-t pt-4 mt-auto">
          <a href="/audit-log" class={navClass('/audit-log')}>
            <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
            <span class="nav-label whitespace-nowrap">Audit Log</span>
          </a>
        </div>
      </aside>

      <main class="flex-1 p-4 md:p-10">
        <div class="max-w-6xl mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('sidebar')!;
      const title = document.getElementById('sidebar-title')!;
      const labels = sidebar.querySelectorAll<HTMLElement>('.nav-label');

      function applyCollapsed(collapsed: boolean) {
        if (collapsed) {
          sidebar.style.width = '56px';
          title.style.display = 'none';
          labels.forEach(el => el.style.display = 'none');
        } else {
          sidebar.style.width = '256px';
          title.style.display = '';
          labels.forEach(el => el.style.display = '');
        }
      }

      // Restore persisted state immediately (no transition flash)
      let collapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      applyCollapsed(collapsed);

      document.getElementById('sidebar-toggle')!.addEventListener('click', () => {
        collapsed = !collapsed;
        localStorage.setItem('sidebar-collapsed', String(collapsed));
        applyCollapsed(collapsed);
      });
    </script>
    <Toaster client:only="react" />
  </body>
</html>
